// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  // url is configured in prisma.config.ts (Prisma v7)
  // directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// Tabel: Story
// Menyimpan cerita pendek berbahasa Jepang
// untuk bahan latihan membaca.
// ─────────────────────────────────────────
model Story {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  translation String?
  focus       String?
  chapter     Int?     // Nomor Bab (1-15) untuk cerita Dekiru; null = cerita legacy
  point       Int?     // Nomor poin cerita dalam bab (1-3); null = cerita legacy
  totalReads  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bookmarks   Bookmark[]
  highlights  Highlight[]

  @@unique([chapter, point])
}

// ─────────────────────────────────────────
// Enum: Role
// ─────────────────────────────────────────
enum Role {
  USER
  ADMIN
}

// ─────────────────────────────────────────
// Tabel: User
// ─────────────────────────────────────────
model User {
  id              Int                @id @default(autoincrement())
  username        String             @unique
  password        String
  role            Role               @default(USER)
  createdAt       DateTime           @default(now())

  progress        LearningProgress[]
  ankiProgress    AnkiProgress[]
  kanaProgress    KanaProgress[]
  kanjiProgress   KanjiProgress[]
  bookmarks       Bookmark[]
  highlights      Highlight[]
  activity        ActivityLog[]
  jlptAttempts    JLPTAttempt[]
  achievements    UserAchievement[]
  chatMessages    ChatMessage[]
  
  katsuyouProgress         KatsuyouLessonProgress[]
  katsuyouReviewCards      KatsuyouReviewCard[]
  katsuyouReviewLogs       KatsuyouReviewLog[]
  katsuyouPracticeAttempts KatsuyouPracticeAttempt[]
  bunpouProgress           BunpouProgress[]
}

// ─────────────────────────────────────────
// Tabel: LearningProgress
// Melacak seberapa sering pengguna mengklik
// / mempelajari sebuah karakter kana.
// userId nullable: NULL = data lama (legacy), non-null = per-user.
// ─────────────────────────────────────────
model LearningProgress {
  id         Int      @id @default(autoincrement())
  character  String   // kana character, e.g. 'あ', 'キャ'
  clickCount Int      @default(0)
  wrongCount Int      @default(0) // berapa kali ditandai salah baca
  lastSeen   DateTime @default(now()) @updatedAt
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([character, userId])
}

// ─────────────────────────────────────────
// Tabel: PrepData
// Menyimpan data persiapan per bab dan poin
// ─────────────────────────────────────────
model PrepData {
  id            Int      @id @default(autoincrement())
  chapter       Int      // Nomor Bab (1-15)
  point         Int      // Nomor Poin (1-3)
  title         String
  conversations Json?    // Array of: { speaker: string, japanese: string, translation: string } (Legacy flat format)
  grammar       Json     // Array of: { pattern: string, explanation: string, examples: { japanese: string, translation: string }[] }
  exercises     Json?    // Array of: { prompt: string, answer: string } (Legacy flat format)
  sections      Json?    // Grouped format: Array of { title: string, conversations: ConversationItem[], exercises: ExerciseItem[] }
  audioFiles    Json     // Array of strings, e.g. ["/audio/7008004_sound01/7008004_DiscA_01.mp3"]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([chapter, point])
}

// ─────────────────────────────────────────
// Tabel: AnkiProgress
// Melacak progres flashcard pengguna (SRS)
// ─────────────────────────────────────────
model AnkiProgress {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: userId, references: [id], onDelete: Cascade)
  cardKey      String   // Format: "Bab {chapterIndex}-{sectionIndex}-{kanji}-{hiragana}"
  chapter      String   // E.g., "Bab １"
  sectionIndex Int      // E.g., 0, 1, 2
  interval     Int      @default(0) // Hari untuk review berikutnya
  ease         Float    @default(2.5) // E-factor
  repetitions  Int      @default(0) // Jumlah pengulangan sukses berturut-turut
  dueDate      DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, cardKey])
}

// ─────────────────────────────────────────
// Tabel: KanjiDictionary
// Kanji/kata yang ditambahkan admin lewat UI /stories/admin/kanji
// untuk vocab yang belum ada di DekiruNihongoGroup.
// ─────────────────────────────────────────
model KanjiDictionary {
  id        Int      @id @default(autoincrement())
  kanji     String   // e.g. "走る"
  hiragana  String   // e.g. "はしる"
  meaningId String?  // terjemahan bahasa Indonesia
  meaningEn String?  // terjemahan bahasa Inggris
  chapter   Int?     // bab terkait (opsional, 1-15)
  notes     String?  // catatan admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([kanji, hiragana])
}

// ─────────────────────────────────────────
// Tabel: AnkiCard
// Menyimpan data kartu hasil import dari file .apkg
// ─────────────────────────────────────────
model AnkiCard {
  id                  String   @id // Note ID asli dari Anki
  deckName            String   // Nama dek asal (e.g., "JLPT N5-N4")
  kanji               String   // Kata / Kanji (Front)
  hiragana            String   // Pembacaan / Hiragana
  translation         String   // Arti dalam Bahasa Indonesia / Inggris
  romaji              String?  // Romaji (opsional)
  audio               String?  // Nama file audio kosakata (Word Audio)
  sentence            String?  // Contoh kalimat Jepang (Sentence)
  sentenceTranslation String?  // Arti contoh kalimat (Sentence Meaning)
  sentenceAudio       String?  // Audio contoh kalimat (Sentence Audio)
  image               String?  // File gambar pendukung (Picture)
  createdAt           DateTime @default(now())

  @@index([deckName])
}


// ═════════════════════════════════════════
// Phase 2 — Models baru untuk fitur Phase 3+
// ═════════════════════════════════════════

// ─────────────────────────────────────────
// Tabel: ActivityLog
// Mencatat event pembelajaran per user
// (untuk streak, dashboard stats, achievements).
// ─────────────────────────────────────────
model ActivityLog {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String   // "story_read" | "anki_review" | "kana_practice" | "kanji_study" | "login" | "prep_open" | "jlpt_mock" | "chat_message"
  refId     String?
  metadata  Json?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, type])
  @@index([type, createdAt])
}

// ─────────────────────────────────────────
// Tabel: Bookmark
// Bookmark kalimat / kata dari cerita.
// ─────────────────────────────────────────
model Bookmark {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId     Int
  story       Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  sentence    String
  hiragana    String?
  translation String?
  charIndex   Int
  length      Int      @default(1)
  note        String?
  createdAt   DateTime @default(now())

  @@index([userId, storyId])
  @@index([userId, createdAt])
}

// ─────────────────────────────────────────
// Tabel: Highlight
// Highlight range karakter dalam cerita.
// ─────────────────────────────────────────
model Highlight {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  storyId   Int
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)
  charIndex Int
  length    Int      @default(1)
  color     String   @default("yellow")
  note      String?
  createdAt DateTime @default(now())

  @@index([userId, storyId])
}

// ─────────────────────────────────────────
// Tabel: KanjiProgress
// SRS state per kanji per user.
// ─────────────────────────────────────────
model KanjiProgress {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kanji       String
  ease        Float    @default(2.5)
  interval    Int      @default(0)
  repetitions Int      @default(0)
  dueDate     DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, kanji])
  @@index([userId, dueDate])
}

// ─────────────────────────────────────────
// Tabel: KanaProgress
// SRS state per kana per user (untuk Kana Practice Mode).
// ─────────────────────────────────────────
model KanaProgress {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  kana        String
  ease        Float    @default(2.5)
  interval    Int      @default(0)
  repetitions Int      @default(0)
  dueDate     DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, kana])
  @@index([userId, dueDate])
}

// ─────────────────────────────────────────
// Tabel: JLPTQuestion
// Bank soal JLPT (N5/N4/N3) per section.
// ─────────────────────────────────────────
model JLPTQuestion {
  id          Int      @id @default(autoincrement())
  level       String
  section     String
  question    String
  prompt      String?
  choices     Json
  answer      String
  explanation String?
  createdAt   DateTime @default(now())

  @@index([level, section])
}

// ─────────────────────────────────────────
// Tabel: JLPTAttempt
// Hasil pengerjaan mock test per user.
// ─────────────────────────────────────────
model JLPTAttempt {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  level     String
  score     Int
  total     Int
  duration  Int
  detail    Json
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([userId, level])
}

// ─────────────────────────────────────────
// Tabel: Achievement
// Definisi achievement (catalog).
// ─────────────────────────────────────────
model Achievement {
  id         Int      @id @default(autoincrement())
  code       String   @unique
  titleEn    String
  titleId    String
  descEn     String
  descId     String
  icon       String
  threshold  Int?
  metric     String?

  unlocks    UserAchievement[]
}

// ─────────────────────────────────────────
// Tabel: UserAchievement
// Relasi user → achievement yang sudah dibuka.
// ─────────────────────────────────────────
model UserAchievement {
  id            Int      @id @default(autoincrement())
  userId        Int
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievementId Int
  achievement   Achievement @relation(fields: [achievementId], references: [id], onDelete: Cascade)
  unlockedAt    DateTime @default(now())

  @@unique([userId, achievementId])
  @@index([userId, unlockedAt])
}

// ─────────────────────────────────────────
// Tabel: ChatMessage
// History percakapan user dengan AI Chat (Gemini).
// ─────────────────────────────────────────
model ChatMessage {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      String
  content   String   @db.Text
  level     String   @default("N5")
  tokens    Int?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// ─────────────────────────────────────────
// Tabel: KatsuyouLessonProgress
// Melacak pelajaran konjugasi kata kerja yang selesai per user
// ─────────────────────────────────────────
model KatsuyouLessonProgress {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  conjugationForm String   // e.g. "masu", "te", "ta", etc.
  completed       Boolean  @default(true)
  completedAt     DateTime @default(now())

  @@unique([userId, conjugationForm])
}

// ─────────────────────────────────────────
// Tabel: KatsuyouReviewCard
// Melacak progres flashcard konjugasi kata kerja (SRS) per user
// ─────────────────────────────────────────
model KatsuyouReviewCard {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verbId          String   // e.g., "iku", "taberu"
  conjugationForm String   // e.g., "te", "ta", "masu", etc.
  repetitions     Int      @default(0)
  easeFactor      Float    @default(2.5)
  interval        Int      @default(0) // dalam hari
  nextReview      DateTime @default(now())
  lastReviewed    DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([userId, verbId, conjugationForm])
  @@index([userId, nextReview])
}

// ─────────────────────────────────────────
// Tabel: KatsuyouReviewLog
// Menyimpan log riwayat review SRS konjugasi
// ─────────────────────────────────────────
model KatsuyouReviewLog {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verbId          String
  conjugationForm String
  rating          String   // "easy" | "good" | "hard"
  repetitions     Int
  easeFactor      Float
  interval        Int
  reviewedAt      DateTime @default(now())
}

// ─────────────────────────────────────────
// Tabel: KatsuyouPracticeAttempt
// Menyimpan riwayat percobaan latihan (Practice) per user
// ─────────────────────────────────────────
model KatsuyouPracticeAttempt {
  id              Int      @id @default(autoincrement())
  userId          Int
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  verbId          String
  conjugationForm String
  exerciseType    String   // "type_a" | "type_b" | "type_c" | "type_d"
  isCorrect       Boolean
  userAnswer      String
  createdAt       DateTime @default(now())
}

// ─────────────────────────────────────────
// Tabel: BunpouProgress
// Melacak pola tata bahasa Bunpou yang selesai dipelajari per user
// ─────────────────────────────────────────
model BunpouProgress {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  patternId String
  completed Boolean  @default(true)
  createdAt DateTime @default(now())

  @@unique([userId, patternId])
}

// ─────────────────────────────────────────
// Tabel: BunpouQuestion
// Bank soal latihan menyusun kalimat untuk pola tata bahasa Bunpou.
// ─────────────────────────────────────────
model BunpouQuestion {
  id           Int      @id @default(autoincrement())
  patternId    String
  english      String
  indonesian   String
  sentenceJp   String
  sentenceKana String
  words        Json
  createdAt    DateTime @default(now())

  @@index([patternId])
}

