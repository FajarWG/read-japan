// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  // url is configured in prisma.config.ts (Prisma v7)
  // directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// Tabel: Story
// Menyimpan cerita pendek berbahasa Jepang
// untuk bahan latihan membaca.
// ─────────────────────────────────────────
model Story {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  translation String?
  focus       String?
  chapter     Int?     // Nomor Bab (1-15) untuk cerita Dekiru; null = cerita legacy
  point       Int?     // Nomor poin cerita dalam bab (1-3); null = cerita legacy
  totalReads  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([chapter, point])
}

// ─────────────────────────────────────────
// Enum: Role
// ─────────────────────────────────────────
enum Role {
  USER
  ADMIN
}

// ─────────────────────────────────────────
// Tabel: User
// ─────────────────────────────────────────
model User {
  id        Int                @id @default(autoincrement())
  username  String             @unique
  password  String
  role      Role               @default(USER)
  createdAt DateTime           @default(now())
  progress  LearningProgress[]
  ankiProgress AnkiProgress[]
}

// ─────────────────────────────────────────
// Tabel: LearningProgress
// Melacak seberapa sering pengguna mengklik
// / mempelajari sebuah karakter kana.
// userId nullable: NULL = data lama (legacy), non-null = per-user.
// ─────────────────────────────────────────
model LearningProgress {
  id         Int      @id @default(autoincrement())
  character  String   // kana character, e.g. 'あ', 'キャ'
  clickCount Int      @default(0)
  wrongCount Int      @default(0) // berapa kali ditandai salah baca
  lastSeen   DateTime @default(now()) @updatedAt
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([character, userId])
}

// ─────────────────────────────────────────
// Tabel: PrepData
// Menyimpan data persiapan per bab dan poin
// ─────────────────────────────────────────
model PrepData {
  id            Int      @id @default(autoincrement())
  chapter       Int      // Nomor Bab (1-15)
  point         Int      // Nomor Poin (1-3)
  title         String
  conversations Json?    // Array of: { speaker: string, japanese: string, translation: string } (Legacy flat format)
  grammar       Json     // Array of: { pattern: string, explanation: string, examples: { japanese: string, translation: string }[] }
  exercises     Json?    // Array of: { prompt: string, answer: string } (Legacy flat format)
  sections      Json?    // Grouped format: Array of { title: string, conversations: ConversationItem[], exercises: ExerciseItem[] }
  audioFiles    Json     // Array of strings, e.g. ["/audio/7008004_sound01/7008004_DiscA_01.mp3"]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@unique([chapter, point])
}

// ─────────────────────────────────────────
// Tabel: AnkiProgress
// Melacak progres flashcard pengguna (SRS)
// ─────────────────────────────────────────
model AnkiProgress {
  id           Int      @id @default(autoincrement())
  userId       Int
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cardKey      String   // Format: "Bab {chapterIndex}-{sectionIndex}-{kanji}-{hiragana}"
  chapter      String   // E.g., "Bab １"
  sectionIndex Int      // E.g., 0, 1, 2
  interval     Int      @default(0) // Hari untuk review berikutnya
  ease         Float    @default(2.5) // E-factor
  repetitions  Int      @default(0) // Jumlah pengulangan sukses berturut-turut
  dueDate      DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@unique([userId, cardKey])
}
