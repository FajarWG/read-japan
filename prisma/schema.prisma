// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../app/generated/prisma"
}

datasource db {
  provider  = "postgresql"
  // url is configured in prisma.config.ts (Prisma v7)
  // directUrl = env("DIRECT_URL")
}

// ─────────────────────────────────────────
// Tabel: Story
// Menyimpan cerita pendek berbahasa Jepang
// untuk bahan latihan membaca.
// ─────────────────────────────────────────
model Story {
  id          Int      @id @default(autoincrement())
  title       String
  content     String
  translation String?
  focus       String?
  totalReads  Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ─────────────────────────────────────────
// Enum: Role
// ─────────────────────────────────────────
enum Role {
  USER
  ADMIN
}

// ─────────────────────────────────────────
// Tabel: User
// ─────────────────────────────────────────
model User {
  id        Int                @id @default(autoincrement())
  username  String             @unique
  name      String
  password  String
  role      Role               @default(USER)
  createdAt DateTime           @default(now())
  progress  LearningProgress[]
}

// ─────────────────────────────────────────
// Tabel: LearningProgress
// Melacak seberapa sering pengguna mengklik
// / mempelajari sebuah karakter kana.
// userId nullable: NULL = data lama (legacy), non-null = per-user.
// ─────────────────────────────────────────
model LearningProgress {
  id         Int      @id @default(autoincrement())
  character  String   // kana character, e.g. 'あ', 'キャ'
  clickCount Int      @default(0)
  wrongCount Int      @default(0) // berapa kali ditandai salah baca
  lastSeen   DateTime @default(now()) @updatedAt
  userId     Int?
  user       User?    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([character, userId])
}
